{
	"compatibility_date": "2025-10-08",
	"main": "src/index.ts",
	"name": "payorbe-music",
	"upload_source_maps": true,
	"workers_dev": true,
	"d1_databases": [
		{
			"binding": "DB",
			"database_id": "40d3d5b2-58e9-4993-b385-8dabde80dda2",
			"database_name": "d1-music-database"
		}
	],
	"r2_buckets": [
		{
			"binding": "MUSIC_BUCKET",
			"bucket_name": "payorbe-music"
		}
	],
	"routes": [
		{
			"pattern": "patacos.com.br/*",
			"zone_name": "patacos.com.br"
		},
		{
			"pattern": "www.patacos.com.br/*",
			"zone_name": "patacos.com.br"
		}
	],
	"observability": {
		"enabled": true
	}
}
